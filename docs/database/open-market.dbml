// Open Market Database Structure
// Paste this into https://dbdiagram.io using DBML format.
// Designed for a South African multi-vendor marketplace with buyer protection,
// separate buyer/seller onboarding, protected payments, delivery confirmation,
// disputes, refunds, reviews, notifications, and messaging.

Project open_market {
  database_type: 'PostgreSQL'
  Note: '''
    Open Market core schema.
    Public users can be buyers, sellers, or both through roles.
    Admin/internal roles should exist in the database, but should not appear on public auth pages.
  '''
}

// =========================
// ENUMS
// =========================

Enum user_status {
  pending
  active
  suspended
  restricted
  deactivated
}

Enum role_name {
  buyer
  seller
  platform_admin
  support_agent
}

Enum verification_status {
  pending
  verified
  rejected
  expired
}

Enum seller_status {
  draft
  pending_verification
  approved
  rejected
  suspended
}

Enum product_status {
  draft
  pending_review
  active
  inactive
  rejected
  archived
}

Enum product_condition {
  new
  like_new
  good
  fair
  used
}

Enum cart_status {
  active
  converted
  abandoned
}

Enum order_status {
  pending_payment
  paid
  processing
  ready_for_delivery
  in_transit
  delivered
  completed
  cancelled
  disputed
  refunded
}

Enum payment_status {
  pending
  authorized
  paid
  failed
  cancelled
  refunded
  partially_refunded
}

Enum protected_payment_status {
  held
  eligible_for_release
  released
  disputed
  refunded
}

Enum delivery_status {
  pending
  arranged
  collected
  in_transit
  delivered
  failed
  returned
}

Enum delivery_method {
  courier
  seller_arranged
  collection
}

Enum dispute_status {
  open
  awaiting_buyer
  awaiting_seller
  under_review
  resolved_buyer
  resolved_seller
  closed
}

Enum dispute_reason {
  item_not_received
  item_not_as_described
  damaged_item
  wrong_item
  payment_issue
  seller_issue
  other
}

Enum refund_status {
  requested
  approved
  rejected
  processing
  completed
  failed
}

Enum review_target_type {
  product
  seller
}

Enum notification_type {
  order_update
  payment_update
  delivery_update
  dispute_update
  refund_update
  message
  account_security
  seller_verification
  system
}

Enum message_thread_type {
  buyer_seller
  dispute
  support
}

Enum payout_status {
  pending
  approved
  processing
  paid
  failed
  cancelled
}

Enum audit_action_type {
  create
  update
  delete
  login
  logout
  status_change
  payment_event
  verification_event
}

// =========================
// AUTH + USERS
// =========================

Table users {
  id uuid [pk, default: `gen_random_uuid()`]
  full_name varchar(160) [not null]
  email varchar(255) [not null, unique]
  phone varchar(40)
  password_hash varchar(255)
  status user_status [not null, default: 'pending']
  email_verified_at timestamptz
  phone_verified_at timestamptz
  last_login_at timestamptz
  suspended_at timestamptz
  suspension_reason text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    email [unique]
    phone
    status
    created_at
  }
}

Table roles {
  id uuid [pk, default: `gen_random_uuid()`]
  name role_name [not null, unique]
  description text
  created_at timestamptz [not null, default: `now()`]
}

Table user_roles {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  role_id uuid [not null]
  assigned_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, role_id) [unique]
  }
}

Table email_verifications {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  email varchar(255) [not null]
  token_hash varchar(255) [not null]
  status verification_status [not null, default: 'pending']
  expires_at timestamptz [not null]
  verified_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    token_hash
    status
  }
}

Table phone_verifications {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  phone varchar(40) [not null]
  otp_hash varchar(255) [not null]
  status verification_status [not null, default: 'pending']
  attempts int [not null, default: 0]
  expires_at timestamptz [not null]
  verified_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    phone
    status
  }
}

Table password_reset_tokens {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  token_hash varchar(255) [not null, unique]
  used_at timestamptz
  expires_at timestamptz [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    token_hash [unique]
  }
}

Table user_sessions {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  refresh_token_hash varchar(255) [not null, unique]
  device_name varchar(160)
  ip_address inet
  user_agent text
  revoked_at timestamptz
  expires_at timestamptz [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    refresh_token_hash [unique]
  }
}

// =========================
// BUYER PROFILE + ADDRESSES
// =========================

Table buyer_profiles {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, unique]
  display_name varchar(160)
  default_delivery_method delivery_method
  marketing_opt_in boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table addresses {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  label varchar(80)
  recipient_name varchar(160) [not null]
  phone varchar(40)
  line1 varchar(255) [not null]
  line2 varchar(255)
  suburb varchar(120)
  city varchar(120) [not null]
  province varchar(80) [not null]
  postal_code varchar(20)
  country varchar(80) [not null, default: 'South Africa']
  is_default boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    city
    province
  }
}

Table buyer_preferences {
  id uuid [pk, default: `gen_random_uuid()`]
  buyer_profile_id uuid [not null]
  category_id uuid [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (buyer_profile_id, category_id) [unique]
  }
}

// =========================
// SELLERS + VERIFICATION
// =========================

Table sellers {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, unique]
  store_name varchar(160) [not null]
  slug varchar(180) [not null, unique]
  bio text
  store_category_id uuid
  city varchar(120)
  province varchar(80)
  status seller_status [not null, default: 'pending_verification']
  rating_avg decimal(3,2) [not null, default: 0]
  rating_count int [not null, default: 0]
  approved_at timestamptz
  suspended_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id [unique]
    slug [unique]
    status
    store_category_id
    province
  }
}

Table seller_verifications {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_id uuid [not null]
  status verification_status [not null, default: 'pending']
  identity_verified boolean [not null, default: false]
  store_reviewed boolean [not null, default: false]
  payout_setup_verified boolean [not null, default: false]
  notes text
  reviewed_by uuid
  reviewed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    seller_id
    status
  }
}

Table payout_accounts {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_id uuid [not null]
  bank_name varchar(120) [not null]
  account_holder varchar(160) [not null]
  account_number_masked varchar(40) [not null]
  branch_code varchar(20)
  is_default boolean [not null, default: false]
  verified_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    seller_id
    is_default
  }
}

// =========================
// CATALOG
// =========================

Table categories {
  id uuid [pk, default: `gen_random_uuid()`]
  parent_id uuid
  name varchar(120) [not null]
  slug varchar(140) [not null, unique]
  description text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    parent_id
    slug [unique]
  }
}

Table products {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_id uuid [not null]
  category_id uuid [not null]
  title varchar(220) [not null]
  slug varchar(260) [not null, unique]
  description text
  condition product_condition [not null, default: 'new']
  status product_status [not null, default: 'draft']
  brand varchar(120)
  price_cents int [not null]
  currency char(3) [not null, default: 'ZAR']
  stock_quantity int [not null, default: 0]
  reserved_quantity int [not null, default: 0]
  city varchar(120)
  province varchar(80)
  published_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    seller_id
    category_id
    slug [unique]
    status
    price_cents
    province
  }
}

Table product_images {
  id uuid [pk, default: `gen_random_uuid()`]
  product_id uuid [not null]
  url text [not null]
  alt_text varchar(255)
  sort_order int [not null, default: 0]
  is_primary boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    product_id
    is_primary
  }
}

Table product_variants {
  id uuid [pk, default: `gen_random_uuid()`]
  product_id uuid [not null]
  sku varchar(100)
  option_name varchar(80)
  option_value varchar(120)
  price_cents int
  stock_quantity int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    product_id
    sku
  }
}

Table product_favorites {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  product_id uuid [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, product_id) [unique]
  }
}

// =========================
// CART + CHECKOUT
// =========================

Table carts {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  status cart_status [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    status
  }
}

Table cart_items {
  id uuid [pk, default: `gen_random_uuid()`]
  cart_id uuid [not null]
  product_id uuid [not null]
  variant_id uuid
  quantity int [not null, default: 1]
  unit_price_cents int [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    cart_id
    product_id
  }
}

// =========================
// ORDERS + PAYMENTS
// =========================

Table orders {
  id uuid [pk, default: `gen_random_uuid()`]
  order_number varchar(40) [not null, unique]
  buyer_id uuid [not null]
  delivery_address_id uuid
  status order_status [not null, default: 'pending_payment']
  payment_status payment_status [not null, default: 'pending']
  subtotal_cents int [not null, default: 0]
  delivery_fee_cents int [not null, default: 0]
  service_fee_cents int [not null, default: 0]
  total_cents int [not null, default: 0]
  currency char(3) [not null, default: 'ZAR']
  placed_at timestamptz
  paid_at timestamptz
  completed_at timestamptz
  cancelled_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    order_number [unique]
    buyer_id
    status
    payment_status
    created_at
  }
}

Table order_items {
  id uuid [pk, default: `gen_random_uuid()`]
  order_id uuid [not null]
  seller_id uuid [not null]
  product_id uuid [not null]
  variant_id uuid
  product_title varchar(220) [not null]
  product_image_url text
  quantity int [not null]
  unit_price_cents int [not null]
  total_price_cents int [not null]
  item_status order_status [not null, default: 'paid']
  created_at timestamptz [not null, default: `now()`]

  indexes {
    order_id
    seller_id
    product_id
    item_status
  }
}

Table payments {
  id uuid [pk, default: `gen_random_uuid()`]
  order_id uuid [not null]
  buyer_id uuid [not null]
  provider varchar(80) [not null]
  provider_reference varchar(160)
  status payment_status [not null, default: 'pending']
  amount_cents int [not null]
  currency char(3) [not null, default: 'ZAR']
  paid_at timestamptz
  failed_reason text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    order_id
    buyer_id
    provider_reference
    status
  }
}

Table protected_payments {
  id uuid [pk, default: `gen_random_uuid()`]
  order_item_id uuid [not null, unique]
  seller_id uuid [not null]
  payment_id uuid [not null]
  status protected_payment_status [not null, default: 'held']
  held_amount_cents int [not null]
  release_eligible_at timestamptz
  released_at timestamptz
  refunded_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    order_item_id [unique]
    seller_id
    payment_id
    status
  }
}

Table order_status_events {
  id uuid [pk, default: `gen_random_uuid()`]
  order_id uuid [not null]
  order_item_id uuid
  status order_status [not null]
  note text
  created_by uuid
  created_at timestamptz [not null, default: `now()`]

  indexes {
    order_id
    order_item_id
    status
    created_at
  }
}

// =========================
// DELIVERY + CONFIRMATION
// =========================

Table deliveries {
  id uuid [pk, default: `gen_random_uuid()`]
  order_item_id uuid [not null, unique]
  seller_id uuid [not null]
  buyer_id uuid [not null]
  method delivery_method [not null]
  status delivery_status [not null, default: 'pending']
  carrier_name varchar(120)
  tracking_number varchar(160)
  collection_code varchar(40)
  estimated_delivery_at timestamptz
  delivered_at timestamptz
  confirmed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    order_item_id [unique]
    seller_id
    buyer_id
    status
    tracking_number
  }
}

Table delivery_codes {
  id uuid [pk, default: `gen_random_uuid()`]
  delivery_id uuid [not null, unique]
  code_hash varchar(255) [not null]
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    delivery_id [unique]
  }
}

Table delivery_events {
  id uuid [pk, default: `gen_random_uuid()`]
  delivery_id uuid [not null]
  status delivery_status [not null]
  location_text varchar(255)
  note text
  created_by uuid
  created_at timestamptz [not null, default: `now()`]

  indexes {
    delivery_id
    status
    created_at
  }
}

// =========================
// DISPUTES + REFUNDS
// =========================

Table disputes {
  id uuid [pk, default: `gen_random_uuid()`]
  dispute_number varchar(40) [not null, unique]
  order_id uuid [not null]
  order_item_id uuid
  buyer_id uuid [not null]
  seller_id uuid [not null]
  reason dispute_reason [not null]
  status dispute_status [not null, default: 'open']
  title varchar(180) [not null]
  description text [not null]
  opened_at timestamptz [not null, default: `now()`]
  resolved_at timestamptz
  resolution_note text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    dispute_number [unique]
    order_id
    order_item_id
    buyer_id
    seller_id
    status
  }
}

Table dispute_messages {
  id uuid [pk, default: `gen_random_uuid()`]
  dispute_id uuid [not null]
  sender_id uuid [not null]
  body text [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    dispute_id
    sender_id
    created_at
  }
}

Table dispute_evidence {
  id uuid [pk, default: `gen_random_uuid()`]
  dispute_id uuid [not null]
  uploaded_by uuid [not null]
  file_url text [not null]
  file_type varchar(80)
  description text
  created_at timestamptz [not null, default: `now()`]

  indexes {
    dispute_id
    uploaded_by
  }
}

Table refunds {
  id uuid [pk, default: `gen_random_uuid()`]
  refund_number varchar(40) [not null, unique]
  order_id uuid [not null]
  order_item_id uuid
  payment_id uuid [not null]
  dispute_id uuid
  buyer_id uuid [not null]
  amount_cents int [not null]
  status refund_status [not null, default: 'requested']
  reason text
  approved_by uuid
  approved_at timestamptz
  processed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    refund_number [unique]
    order_id
    payment_id
    dispute_id
    buyer_id
    status
  }
}

// =========================
// REVIEWS
// =========================

Table reviews {
  id uuid [pk, default: `gen_random_uuid()`]
  order_item_id uuid [not null]
  reviewer_id uuid [not null]
  seller_id uuid
  product_id uuid
  target_type review_target_type [not null]
  rating int [not null]
  title varchar(160)
  body text
  is_published boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    order_item_id
    reviewer_id
    seller_id
    product_id
    target_type
  }
}

// =========================
// MESSAGING + NOTIFICATIONS
// =========================

Table message_threads {
  id uuid [pk, default: `gen_random_uuid()`]
  type message_thread_type [not null]
  buyer_id uuid
  seller_id uuid
  order_id uuid
  dispute_id uuid
  subject varchar(180)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    buyer_id
    seller_id
    order_id
    dispute_id
    type
  }
}

Table messages {
  id uuid [pk, default: `gen_random_uuid()`]
  thread_id uuid [not null]
  sender_id uuid [not null]
  body text [not null]
  read_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    thread_id
    sender_id
    created_at
  }
}

Table notifications {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  type notification_type [not null]
  title varchar(180) [not null]
  body text
  link_url text
  read_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    type
    read_at
    created_at
  }
}

// =========================
// SELLER PAYOUTS
// =========================

Table seller_payouts {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_id uuid [not null]
  payout_account_id uuid
  status payout_status [not null, default: 'pending']
  amount_cents int [not null]
  currency char(3) [not null, default: 'ZAR']
  provider_reference varchar(160)
  processed_at timestamptz
  failed_reason text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    seller_id
    payout_account_id
    status
  }
}

Table seller_payout_items {
  id uuid [pk, default: `gen_random_uuid()`]
  seller_payout_id uuid [not null]
  protected_payment_id uuid [not null, unique]
  amount_cents int [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    seller_payout_id
    protected_payment_id [unique]
  }
}

// =========================
// AUDIT + SUPPORT
// =========================

Table support_cases {
  id uuid [pk, default: `gen_random_uuid()`]
  case_number varchar(40) [not null, unique]
  user_id uuid
  subject varchar(180) [not null]
  description text [not null]
  status varchar(40) [not null, default: 'open']
  priority varchar(40) [not null, default: 'normal']
  assigned_to uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  closed_at timestamptz

  indexes {
    case_number [unique]
    user_id
    status
    assigned_to
  }
}

Table audit_logs {
  id uuid [pk, default: `gen_random_uuid()`]
  actor_id uuid
  action audit_action_type [not null]
  entity_type varchar(80) [not null]
  entity_id uuid
  ip_address inet
  metadata jsonb
  created_at timestamptz [not null, default: `now()`]

  indexes {
    actor_id
    entity_type
    entity_id
    action
    created_at
  }
}

// =========================
// RELATIONSHIPS
// =========================

Ref: user_roles.user_id > users.id [delete: cascade]
Ref: user_roles.role_id > roles.id [delete: cascade]

